# 火山方舟 Agent Plan API 私密配置示例
# 请复制本文件为 .env 并填写你的真实 VOLC_API_KEY
VOLC_API_KEY=your_volcano_ark_api_key_here

# 火山方舟 Agent Plan OpenAI 协议兼容端点
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3

# 指定模型名称 (如 doubao-seed-2.1-turbo, deepseek-v4-pro, kimi-k3 等)
VOLC_MODEL_NAME=doubao-seed-2.1-turbo

# 火山方舟 Seedream 生图模型
VOLC_IMAGE_MODEL_NAME=doubao-seedream-5.0-lite
VOLC_IMAGE_SIZE=2K

# 生图文件对前端和 Chrome 插件可访问的地址
PUBLIC_BASE_URL=http://localhost:8888
